##################### UI configuration ####################
RAILS_ENV=development
SITE=Testportal
ORG=LIRMM
ORG_URL=http://www.lirmm.fr

READ_ONLY_PORTAL=false

UI_URL=http://localhost:3000
API_URL=http://localhost:9393
API_KEY=1de0a270-29c5-4dda-b043-7c3580628cd5

UI_THEME=ontoportal

TWITTER_NEWS=

BIOMIXER_URL=
BIOMIXER_APIKEY=

ANNOTATOR_URL=

FAIRNESS_DISABLED=false
FAIRNESS_URL=

NCBO_ANNOTATORPLUS_ENABLED=false
NCBO_ANNOTATOR_URL=
NCBO_API_KEY=

#################### Smart assistant (LLM + MCP) ####################
## Enable the smart assistant pop-up (also requires the LLM settings below)
ASSISTANT_ENABLED=false
## OpenAI-compatible Chat Completions endpoint (base URL ".../v1" or full ".../chat/completions")
ASSISTANT_LLM_API_URL=
## API key for the LLM endpoint (kept server-side, never sent to the browser)
ASSISTANT_LLM_API_KEY=
## Model id, e.g. gpt-4o-mini
ASSISTANT_LLM_MODEL=
## AgroPortal MCP server (defaults to https://mcp.agroportal.eu/)
ASSISTANT_MCP_URL=https://mcp.agroportal.eu/

SUPPORT_EMAIL=sifrportal-support@lirmm.fr
RELEASE_VERSION="OntoPortal Appliance 3.0.1"

ANALYTICS_ID=
USE_RECAPTCHA=false
####################  Buidling the API for running tests ####################
## An ontology that will be imported in the starting of the API server
STARTER_ONTOLOGY=STY
## API key of a remote API used to download the starter ontology
OP_API_KEY=8b5b7825-538d-40e0-9e9e-5ab9274a9aeb
## API url of the remote API used to download the starter ontology
OP_API_URL="https://data.bioontology.org"

## Image repositroy from which the ontoportal api will be built
API_IMAGE_REPOSITORY=agroportal
## Image tag/version from which the ontoportal api will be built
API_IMAGE_TAG=master

AGENTS_ENABLED=true

SPARQL_ENDPOINT_URL="https://sparql.stage.agroportal.eu/sparql" 

SIDEKIQ_UI_URL=${API_URL}/sidekiq